{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@tabula-md/tabula": ["packages/tabula/src/index.ts"],
      "@tabula-md/tabula/workbench": ["packages/tabula/src/workbench/index.ts"],
      "@tabula-md/tabula-private/workbench": ["packages/tabula/src/workbench/internal.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["tabula-app/src", "packages/tabula/src"],
  "references": []
}
