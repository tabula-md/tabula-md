rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function validRoomId(roomId) {
      return roomId is string && roomId.matches('^[A-Za-z0-9_-]{1,64}$');
    }

    function validRoomDocument(data) {
      return data.keys().hasOnly([
          'formatVersion',
          'stateVersion',
          'iv',
          'ciphertext',
          'updatedAt',
        ])
        && data.formatVersion == 1
        && data.stateVersion is int
        && data.stateVersion >= 1
        && data.iv is bytes
        && data.ciphertext is bytes
        && data.updatedAt == request.time;
    }

    match /rooms/{roomId} {
      allow get: if validRoomId(roomId);
      allow list: if false;
      allow create: if validRoomId(roomId)
        && validRoomDocument(request.resource.data)
        && request.resource.data.stateVersion == 1;
      allow update: if validRoomId(roomId)
        && validRoomDocument(request.resource.data)
        && request.resource.data.stateVersion == resource.data.stateVersion + 1;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
