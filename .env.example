# Local room server used by Share > Collaborate > Start session.
VITE_TABULA_ROOM_URL=http://localhost:3002

# Local encrypted Export link service.
VITE_TABULA_JSON_URL=http://localhost:3004

# Required for Live collaboration. Firestore stores only the checkpoint pointer;
# Storage receives encrypted checkpoint bytes. Room keys stay in URL fragments.
# VITE_TABULA_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}

# Local Firebase Emulator Suite. In development this also supplies a safe demo
# Firebase config, so no production credentials are needed.
VITE_TABULA_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_TABULA_FIRESTORE_EMULATOR_PORT=8080
VITE_TABULA_FIREBASE_STORAGE_EMULATOR_PORT=9199
