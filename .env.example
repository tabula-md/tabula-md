# Local room server used by Share > Collaborate > Start session.
VITE_TABULA_ROOM_URL=http://localhost:3002

# Local encrypted read-only #json share-link service.
VITE_TABULA_JSON_URL=http://localhost:3004

# Optional Firebase Web SDK config JSON for encrypted live-room recovery.
# Leave unset for relay-only local collaboration.
# VITE_TABULA_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}
