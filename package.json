{
  "name": "tabula-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "tabula-app",
    "packages/tabula"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:local": "VITE_TABULA_FIREBASE_EMULATOR_HOST=127.0.0.1 vite --host 0.0.0.0",
    "dev:firebase": "npx --yes firebase-tools@15.22.4 emulators:start --project tabula-local --config scripts/browser-smoke/fixtures/firebase/firebase.json",
    "build": "tsc && vite build",
    "build:core": "npm run build -w @tabula-md/tabula",
    "check:core-runtime": "npm run build:core && node scripts/check-core-runtime.mjs",
    "check:core-package": "npm run build:core && node scripts/check-tabula-package.mjs",
    "perf:preview-architecture": "npm run build:core && node scripts/preview-architecture-benchmark.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "surface:check": "node scripts/public-surface-check.mjs",
    "boundary:check": "node scripts/check-boundaries.mjs",
    "test": "vitest run",
    "test:browser": "node scripts/browser-smoke.mjs",
    "test:browser:workspace": "npm run test:browser -- --suite=workspace",
    "test:browser:editor": "npm run test:browser -- --suite=editor-preview,editor-preview-sync,editor-preview-typography,editor-search-layout,editor-search-source,editor-search-replace,editor-search-preview,editor-search-focus-history,editor-selection-comments,split-layout",
    "test:browser:editor-certification": "npm run test:browser -- --suite=editor-certification",
    "test:browser:layout": "npm run test:browser -- --suite=layout",
    "test:browser:panels": "npm run test:browser -- --suite=panels",
    "test:browser:collab": "npm run test:browser -- --suite=collaboration",
    "test:browser:collaboration-editor-torture": "npm run test:browser -- --suite=collaboration-editor-torture",
    "test:browser:collaboration-memory": "npm run test:browser -- --suite=collaboration-memory",
    "test:browser:json-share": "npm run test:browser -- --suite=json-share",
    "test:browser:performance": "npm run test:browser -- --suite=performance",
    "bundle:check": "node scripts/check-bundle-chunks.mjs",
    "test:surface-colors": "node scripts/check-surface-colors.mjs",
    "lint:fast": "oxlint tabula-app/src packages/tabula/src scripts --deny-warnings"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@tanstack/react-virtual": "^3.14.5",
    "@vitejs/plugin-react": "^5.0.0",
    "dexie": "^4.4.4",
    "fflate": "^0.8.3",
    "firebase": "^12.15.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lib0": "^0.2.117",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-deflist": "^1.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-supersub": "^1.0.0",
    "socket.io-client": "^4.8.1",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yaml": "^2.9.0",
    "yjs": "^13.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.60.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
