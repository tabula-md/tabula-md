{
  "name": "@tabula-md/tabula",
  "version": "0.9.0",
  "description": "Tabula.md document, workspace CRDT, protocol, share-link, and embeddable workbench contracts.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/workbench.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collaboration": {
      "types": "./dist/collaboration.d.ts",
      "import": "./dist/collaboration.js"
    },
    "./data/encryption": {
      "types": "./dist/data/encryption.d.ts",
      "import": "./dist/data/encryption.js"
    },
    "./data/encode": {
      "types": "./dist/data/encode.d.ts",
      "import": "./dist/data/encode.js"
    },
    "./data/json": {
      "types": "./dist/data/json.d.ts",
      "import": "./dist/data/json.js"
    },
    "./data/restore": {
      "types": "./dist/data/restore.d.ts",
      "import": "./dist/data/restore.js"
    },
    "./room": {
      "types": "./dist/room/envelope.d.ts",
      "import": "./dist/room/envelope.js"
    },
    "./room-client": {
      "types": "./dist/roomClient.d.ts",
      "import": "./dist/roomClient.js"
    },
    "./share-link": {
      "types": "./dist/jsonShareLinkModel.d.ts",
      "import": "./dist/share-link.js"
    },
    "./text-patches": {
      "types": "./dist/textPatches.d.ts",
      "import": "./dist/text-patches.js"
    },
    "./workspace-limits": {
      "types": "./dist/workspaceLimits.d.ts",
      "import": "./dist/workspace-limits.js"
    },
    "./workbench": {
      "types": "./src/workbench/index.d.ts",
      "import": "./dist/workbench.js"
    },
    "./workbench.css": "./dist/workbench.css"
  },
  "files": [
    "dist/**/*.css",
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "src/workbench/index.d.ts",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tabula-md/tabula-md.git",
    "directory": "packages/tabula"
  },
  "homepage": "https://github.com/tabula-md/tabula-md/tree/main/packages/tabula#readme",
  "bugs": {
    "url": "https://github.com/tabula-md/tabula-md/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "markdown",
    "local-first",
    "collaboration",
    "e2ee",
    "tabula"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:js",
    "build:js": "vite build --config vite.config.ts",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "npm run build && node ../../scripts/check-tabula-package.mjs"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "lib0": "^0.2.117",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
